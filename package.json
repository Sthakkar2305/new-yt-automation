{
  "name": "yt-shorts-automation",
  "version": "1.0.0",
  "description": "100% FREE fully autonomous YouTube Shorts automation for AI Facts / Future Tech",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "pipeline": "node src/pipeline/orchestrator.js",
    "pipeline:single": "node src/pipeline/orchestrator.js --single",
    "pipeline:upload": "node src/pipeline/orchestrator.js --single --upload",
    "youtube:reauth": "node src/utils/youtube-reauth.js",
    "youtube:auth-check": "node src/utils/youtube-auth-check.js",
    "youtube:status": "node src/utils/youtube-video-status.js",
    "image:test": "node src/utils/test-image-generation.js",
    "cron": "node src/cron/scheduler.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "health": "curl http://localhost:3000/health",
    "cleanup": "node src/utils/cleanup.js",
    "setup:check": "node src/utils/setup-check.js"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/genai": "^2.8.0",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.7",
    "cheerio": "^1.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^140.0.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "p-retry": "^6.2.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
