# ============================================
# YouTube Shorts Automation - 100% FREE Config
# ============================================

# Server
NODE_ENV=development
PORT=3000
API_SECRET_KEY=your_secret_key_here

# ============================================
# DATABASE - Supabase (FREE TIER: 500MB, 50K rows)
# ============================================
# s
# ============================================
# AI - Google Gemini (FREE: 15 RPM, 1M tokens/day)
# Get key: https://aistudio.google.com/apikey
# ============================================
GEMINI_API_KEY=AIzaSyCx0dv2iGdOeunkX_11-u3qM4NTSwBSzgM

# ============================================
# IMAGE GENERATION - LOCAL UNLIMITED MODE
# Best option: run a local Stable Diffusion WebUI/Forge API with --api.
# API docs: http://127.0.0.1:7860/docs
# Recommended open model: FLUX.1-schnell where supported, or any SDXL model installed locally.
# If the local API is not running, the app uses its offline renderer fallback.
# ============================================
IMAGE_PROVIDER=local-stable-diffusion
STABLE_DIFFUSION_API_URL=http://127.0.0.1:7860
STABLE_DIFFUSION_MODEL=
STABLE_DIFFUSION_SAMPLER=DPM++ 2M Karras
STABLE_DIFFUSION_STEPS=8
STABLE_DIFFUSION_CFG_SCALE=2.5
STABLE_DIFFUSION_WIDTH=768
STABLE_DIFFUSION_HEIGHT=1344
STABLE_DIFFUSION_TIMEOUT_MS=180000

# ============================================
# VOICE - Edge TTS (FREE, NO KEY)
# Uses Microsoft Edge's free TTS engine
# Requires: pip install edge-tts
# ============================================
# Nothing to configure!

# ============================================
# YOUTUBE DATA API v3 (FREE: 10,000 units/day)
# Setup: https://console.cloud.google.com
# ============================================
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# ============================================
# SCHEDULING (IST timezone)
# ============================================
TIMEZONE=Asia/Kolkata
UPLOAD_SCHEDULE_1=11:00
UPLOAD_SCHEDULE_2=19:00
VIDEOS_PER_DAY=2

# ============================================
# PROCESSING
# ============================================
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
TEMP_DIR=./temp
OUTPUT_DIR=./output
CLEANUP_TEMP_AFTER_UPLOAD=false

# ============================================
# CHANNEL CONFIG
# ============================================
CHANNEL_ID=your_channel_id
CHANNEL_NAME=AI Facts & Future Tech
NICHE=ai-future-tech
